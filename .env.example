# Alchemy API key for Ethereum mainnet (PAYG tier is fine).
# https://dashboard.alchemy.com/
ALCHEMY_API_KEY=

# SQLite location. The file and parent directory will be created on first run.
DATABASE_URL=sqlite://data/unmask.db

# ENS reverse-resolution + text-record service. The default is the
# community REST shim at api.ensideas.com; override with any endpoint
# that returns { name, twitter, github, telegram } for /<address>.
ENS_RESOLVER_URL=https://api.ensideas.com/ens/resolve

# Safe Transaction Service base URL. The default points at the
# Mainnet instance; switch to the matching network's host when
# working on other chains.
SAFE_TX_SERVICE_URL=https://safe-transaction-mainnet.safe.global
