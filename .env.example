# Alchemy API key. The key MUST be provisioned for the same network
# as ALCHEMY_BASE_URL below — a Scroll-mainnet key against the
# eth-mainnet base URL returns 403.
# https://dashboard.alchemy.com/
ALCHEMY_API_KEY=

# Alchemy base URL up to (but not including) the API key segment.
# Default targets Ethereum mainnet. For other networks use the
# matching host:
#   Ethereum mainnet:  https://eth-mainnet.g.alchemy.com/v2
#   Scroll mainnet:    https://scroll-mainnet.g.alchemy.com/v2
#   Optimism mainnet:  https://opt-mainnet.g.alchemy.com/v2
# Note: ENS resolution (api.ensideas.com) and the CEX blacklist are
# Ethereum-mainnet-specific. Running against an L2 will surface no
# `ens_handle` evidence and the funder fan-out cap will be doing more
# of the heavy lifting since the blacklist won't match L2 bridges.
ALCHEMY_BASE_URL=https://eth-mainnet.g.alchemy.com/v2

# Comma-separated list of transfer categories for alchemy_getAssetTransfers.
# `internal` is rejected by every chain other than Ethereum mainnet and
# Polygon. For Scroll / Optimism / Arbitrum / etc. set this to
# `external,erc20`.
ALCHEMY_TRANSFER_CATEGORIES=external,internal,erc20

# SQLite location. The file and parent directory will be created on first run.
DATABASE_URL=sqlite://data/unmask.db

# ENS reverse-resolution + text-record service. The default is the
# community REST shim at api.ensideas.com; override with any endpoint
# that returns { name, twitter, github, telegram } for /<address>.
ENS_RESOLVER_URL=https://api.ensideas.com/ens/resolve

# Safe Transaction Service base URL. Must match ALCHEMY_BASE_URL's
# network. Examples:
#   Ethereum mainnet:  https://safe-transaction-mainnet.safe.global
#   Scroll mainnet:    https://transaction-scroll.safe.global
#   Optimism mainnet:  https://safe-transaction-optimism.safe.global
SAFE_TX_SERVICE_URL=https://safe-transaction-mainnet.safe.global
